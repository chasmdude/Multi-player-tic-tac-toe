{
  "compilerOptions": {
    "target": "es5",
    "lib": ["es5", "es2015", "es2016", "es2017", "es2018"],
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "outDir": "./build",
    "rootDir": "./src",
    "moduleResolution": "node",
    "module": "commonjs",
    "esModuleInterop": true,
    "typeRoots": ["./src"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
